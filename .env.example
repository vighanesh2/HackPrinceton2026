# From Supabase: Project Settings → API (or Connect dialog).
# Use the project URL and the anon (public) key. New projects may show a "publishable" key instead — that works too.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: if your dashboard only shows the new publishable key, use this name instead of ANON_KEY:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Local Ollama (PLAN-HackPrinceton.md)
LLAMA_BASE_URL=http://127.0.0.1:11434
LLAMA_MODEL=qwen3:14b
LLAMA_FAST_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
